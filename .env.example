# =================================================================
# OpenCouncil Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Variables with defaults (like NODE_ENV) are not listed here.
# See docs/environment-variables.md for a full list and details.
# =================================================================

# ---------------------------------
# Database Connection
# ---------------------------------
# These are used by the application to connect to the database.
# When using the local Docker setup, these are overridden by the script.
DATABASE_URL=
DIRECT_URL=

# ---------------------------------
# Database Initialization (for local Docker setup)
# ---------------------------------
# These are used by the Docker container to initialize the PostgreSQL database.
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=development

# ---------------------------------
# Application URLs
# ---------------------------------
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------
# Required API Keys & Secrets
# ---------------------------------
RESEND_API_KEY=your_resend_api_key
# Sender ("from") address for sign-in magic-link emails.
# Local dev: use Resend's test sender so you don't need a verified domain.
# Note: with onboarding@resend.dev, Resend only delivers to the email that owns
# the API key, so sign in with that email (or set DEV_EMAIL_OVERRIDE below).
AUTH_EMAIL_FROM="OpenCouncil <onboarding@resend.dev>"
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
TASK_API_URL=http://localhost:3005
TASK_API_KEY=your_task_api_key
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
# Used by NextAuth.js for session encryption. Generate a secure random string for production.
NEXTAUTH_SECRET=your_generated_secret_here

# Google Calendar Integration
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_ENABLED=

# ---------------------------------
# Bird (WhatsApp / SMS notifications)
# ---------------------------------
# Full setup walkthrough in docs/bird-setup.md.
BIRD_WORKSPACE_ID=
BIRD_API_KEY=
BIRD_WHATSAPP_CHANNEL_ID=
BIRD_SMS_CHANNEL_ID=
BIRD_WHATSAPP_TEMPLATE_WELCOME=
BIRD_WHATSAPP_TEMPLATE_BEFORE_MEETING=
BIRD_WHATSAPP_TEMPLATE_AFTER_MEETING=
# Shared secret for HMAC verification of inbound Bird webhook events.
# Generate with: openssl rand -base64 32
BIRD_WEBHOOK_SECRET=

# ---------------------------------
# Storage (e.g., Digital Ocean Spaces)
# ---------------------------------
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_KEY=your_do_spaces_key
DO_SPACES_SECRET=your_do_spaces_secret
DO_SPACES_BUCKET=your_do_spaces_bucket
CDN_URL=https://data.opencouncil.gr

# ---------------------------------
# Cron Jobs
# ---------------------------------
# Secret for authenticating cron endpoints (e.g., /api/cron/poll-decisions)
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ---------------------------------
# Cache (Valkey/Redis)
# ---------------------------------
# Shared cache for multi-instance deployments.
# DO managed Valkey: valkeys://user:pass@host:port/0 (path selects logical db)
# Local Docker: redis://localhost:6379
# Leave empty for in-memory cache (single-instance/dev).
CACHE_URL=

# ---------------------------------
# Preview Server (for --preview-db flag)
# ---------------------------------
# SSH target for connecting to the preview server's database.
# Only needed when using: nix run .#dev -- --preview-db=N
# OC_PREVIEW_SSH=root@159.89.98.26

# ---------------------------------
# Optional Variables
# ---------------------------------
# Basic Auth (if you want to password-protect your deployment)
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# ---------------------------------
# PostHog Analytics (optional)
# ---------------------------------
# EU cloud project token (public by design, shipped to the browser).
# Leave empty to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
